{
  "name": "aws-lambda-devkit",
  "version": "0.1.5",
  "description": "Local AWS Lambda development toolkit (npm: aws-lambda-devkit, CLI: lamkit) — invoke handlers locally with AWS-shaped events",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/asimsheikh12/lambda-devkit.git"
  },
  "homepage": "https://github.com/asimsheikh12/lambda-devkit#readme",
  "bugs": {
    "url": "https://github.com/asimsheikh12/lambda-devkit/issues"
  },
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "lamkit": "dist/cli.js"
  },
  "files": [
    "dist",
    "templates",
    "docs",
    "README.md",
    "CHANGELOG.md"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./config": {
      "types": "./dist/config/types.d.ts",
      "import": "./dist/config/types.js"
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "npm run typecheck && npm run lint:eslint",
    "lint:eslint": "eslint src",
    "audit": "npm audit --audit-level=moderate",
    "security": "npm run audit && npm run lint:eslint",
    "test": "npm run build && node scripts/run-tests.mjs",
    "pack:check": "npm run build && node scripts/pack-check.mjs",
    "publish:dry-run": "bash scripts/publish-dry-run.sh",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@types/aws-lambda": "^8.10.162",
    "commander": "^15.0.0",
    "picocolors": "^1.1.1",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "@aws-sdk/client-sns": "^3.0.0",
    "@aws-sdk/client-sqs": "^3.0.0",
    "tsx": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "@aws-sdk/client-sns": {
      "optional": true
    },
    "@aws-sdk/client-sqs": {
      "optional": true
    },
    "tsx": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "eslint": "^9.39.4",
    "eslint-plugin-sonarjs": "^4.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.62.1"
  },
  "keywords": [
    "aws",
    "lambda",
    "local",
    "development",
    "sqs",
    "cli"
  ]
}
